# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite database file path
DATABASE_URL=./data/minibot.db

# Optional: comma-separated Telegram user IDs allowed to use the bot (leave empty to allow everyone)
ALLOWED_USER_IDS=

# Gemini model to use
GEMINI_MODEL=gemini-2.0-flash

# Max conversation history messages to send to Gemini (controls context size)
MAX_HISTORY_MESSAGES=20

# Node environment
NODE_ENV=development

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# How often to edit the Telegram message during streaming (ms). Min 200, max 5000.
STREAM_THROTTLE_MS=800
