# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Cloud project ID (required for Vertex AI / ADC)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Cloud region for Vertex AI (default: us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# Path to GCP Service Account key JSON (required on VPS/Docker — not needed for local dev with gcloud ADC)
# On VPS: place the key at /opt/minibot/gcp-sa-key.json; docker-compose.prod.yml mounts it to /app/gcp-sa-key.json
# GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-sa-key.json

# PostgreSQL connection string (full URL)
# Docker: use "postgres" as the host (the Docker Compose service name)
# Local dev: use "localhost"
DATABASE_URL=postgresql://minibot:change_me_in_production@postgres:5432/minibot

# Optional: comma-separated Telegram user IDs allowed to use the bot (leave empty to allow everyone)
ALLOWED_USER_IDS=

# Gemini model to use (via Vertex AI)
GEMINI_MODEL=gemini-3.0-flash

# Max conversation history messages to send to Gemini (controls context size)
MAX_HISTORY_MESSAGES=20

# Node environment
NODE_ENV=development

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# How often to edit the Telegram message during streaming (ms). Min 200, max 5000.
STREAM_THROTTLE_MS=800
